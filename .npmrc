# Default registry: the public npm registry (the primary home of llm-ledger)
registry=https://registry.npmjs.org/

# Route the @phyoeblitz scope to GitHub Packages, per
# https://docs.github.com/en/packages/working-with-a-github-packages-registry/working-with-the-npm-registry
# The mirror copy is published there as @phyoeblitz/llm-ledger.
@phyoeblitz:registry=https://npm.pkg.github.com

# Attach a signed provenance statement on publish (automatic with
# trusted publishing; this also covers manual token-based publishes)
provenance=true

# Pin exact versions when installing new dependencies
save-exact=true

# Fail installs on npm versions that don't match the lockfile format
lockfile-version=3
