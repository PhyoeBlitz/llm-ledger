{
  "name": "llm-ledger",
  "version": "0.1.0",
  "description": "Zero-dependency token usage and cost tracker for LLM APIs (Anthropic Claude, OpenAI, and any custom model). Track spend, cache savings, and budgets across requests.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "llm",
    "ai",
    "cost",
    "tokens",
    "usage",
    "tracker",
    "anthropic",
    "claude",
    "openai",
    "budget",
    "pricing",
    "prompt-caching"
  ],
  "author": "phyoeblitz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phyoeblitz/llm-ledger.git"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
